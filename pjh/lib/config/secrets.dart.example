// ============================================================
// secrets.dart 설정 가이드
// ============================================================
// 1. 이 파일을 복사하여 같은 위치에 'secrets.dart'로 저장
// 2. 각 항목에 실제 API 키 입력
// 3. secrets.dart는 .gitignore에 등록되어 있으므로 git에 절대 커밋되지 않음
// ============================================================

class Secrets {
  // [필수] Google Gemini API 키
  // 발급: https://aistudio.google.com/apikey
  static const String geminiApiKey = 'YOUR_GEMINI_API_KEY_HERE';

  // [필수] Supabase 설정
  // Supabase Dashboard > Settings > API 에서 확인
  static const String supabaseUrl = 'YOUR_SUPABASE_URL';
  static const String supabaseAnonKey = 'YOUR_SUPABASE_ANON_KEY';

  // [필수] 카카오 로그인용 내부 시크릿 (임의 문자열)
  // 변경 시 기존 카카오 사용자 재로그인 필요
  static const String kakaoPasswordSalt = 'YOUR_RANDOM_SECRET_STRING';

  // 소셜 로그인
  static const String googleClientId =
      'YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com';
  static const String kakaoAppKey = 'YOUR_KAKAO_APP_KEY';
}
